# Public site URL — used for canonical URLs, sitemap, OpenGraph, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://venkatesh.dev

# GitHub username for live GitHub stats on the hero section.
NEXT_PUBLIC_GITHUB_USERNAME=venkatesh-sethumurugan

# Optional: a GitHub personal access token (read-only, public_repo scope or none)
# raises the unauthenticated rate limit for the server-side stats fetch.
GITHUB_TOKEN=

# Optional: Formspree / Resend / etc. endpoint for the contact form.
NEXT_PUBLIC_CONTACT_ENDPOINT=
