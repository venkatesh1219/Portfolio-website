# Public site URL — used for canonical URLs, sitemap, OpenGraph, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://venkatesh-portfolio-website.vercel.app

# GitHub username for live GitHub stats on the hero section.
NEXT_PUBLIC_GITHUB_USERNAME=venkatesh1219

# Optional: a GitHub personal access token (read-only) raises the
# unauthenticated rate limit for the server-side stats fetch.
GITHUB_TOKEN=

# Optional: Formspree / Resend / etc. endpoint for the contact form.
NEXT_PUBLIC_CONTACT_ENDPOINT=

# ---- Admin dashboard (/admin) ----
# Credentials for the admin login. Set BOTH to enable sign in.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# ---- Database (Vercel Postgres / Neon) ----
# Set automatically when you add a Postgres store in Vercel and link it.
# Powers blog post CRUD and first-party visitor + Web Vitals analytics.
# Locally, paste your Neon connection string here.
DATABASE_URL=
